{
  "name": "paddlelink-ping-pong",
  "version": "1.0.0",
  "description": "Motion-controlled table tennis game using phone as paddle",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:mobile": "npm -w @paddlelink/mobile run dev",
    "dev:desktop": "npm -w @paddlelink/desktop run dev",
    "dev:server": "npm -w @paddlelink/server run dev",
    "build": "npm run build --workspaces",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:desktop\" \"npm run dev:mobile\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
